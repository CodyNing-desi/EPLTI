# MySQL 连接配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=eplti

# 服务端口
PORT=3001

# 生产环境
# NODE_ENV=production

# 管理后台密钥 (用于导出数据)
ADMIN_KEY=your_secret_admin_key_here

# ========================================
# AI 配置 — 兼容所有 OpenAI 格式 API
# ========================================
# 只需要改这三项就能切换不同的 AI 供应商:
#
# --- DeepSeek V4 (默认) ---
MIMO_API_KEY=your_deepseek_api_key
MIMO_API_URL=https://api.deepseek.com/v1/chat/completions
MIMO_MODEL=deepseek-chat
#
# --- 小米 MiMo ---
# MIMO_API_KEY=your_mimo_api_key
# MIMO_API_URL=https://api.xiaomimimo.com/v1/chat/completions
# MIMO_MODEL=mimo-v2.5-pro
#
# --- OpenAI ---
# MIMO_API_KEY=sk-xxxx
# MIMO_API_URL=https://api.openai.com/v1/chat/completions
# MIMO_MODEL=gpt-4o
