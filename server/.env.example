# MySQL 连接配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=eplti

# 服务端口
PORT=3001

# 微信分享相关 (可选)
# WECHAT_APP_ID=你的AppID
# WECHAT_APP_SECRET=你的AppSecret

# CORS 跨域配置 (可选，逗号分隔，默认允许 localhost:5173)
# CORS_ORIGINS=https://你的域名.com,https://另一个域名.com

# 生产环境
# NODE_ENV=production
